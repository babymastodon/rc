# Copy to ~/.config/hwstat/config.toml or pass with:
#   hwstat --config ./sensors.toml
#
# Run `hwstat --check` to list the hwmon device names and sensor keys on this
# machine, then write `match`/`key` rules against them. `hwstat --all`
# temporarily shows every unconfigured device while you discover keys.

[display]
# false: show only the devices configured below (plus nvme storage).
# true: also show any unconfigured hwmon device.
show_unconfigured = false

# A device that already exposes good kernel labels (e.g. the ASUS `asusec` EC
# or `k10temp`) only needs grouping/ordering -- omit [[devices.sensors]] and the
# driver labels are used as-is.
[[devices]]
match = "k10temp"
label = "CPU"
group = "Board"
order = 5

[[devices]]
match = "asusec"
label = "Motherboard"
group = "Board"
order = 10

# A device with generic kernel labels (temp1/fan2/...) can be relabeled,
# reordered, or hidden per sensor:
#
# [[devices]]
# match = "nct6798"
# label = "Super I/O"
# group = "Board"
# order = 20
#
# [[devices.sensors]]
# key = "temp1"
# label = "VRM"
# order = 10
#
# [[devices.sensors]]
# key = "fan3"
# hidden = true

[psu]
enabled = true
device = "/dev/msi-ai1600t"
timeout = 2.0
label = "Power supply"
group = "Power"
order = 200

[[psu.metrics]]
key = "output_power"
label = "Output"
order = 10

[[psu.metrics]]
key = "input_power"
label = "Input"
order = 15

[[psu.metrics]]
key = "efficiency"
label = "Efficiency"
order = 20

[[psu.metrics]]
key = "fan_speed"
label = "PSU fan"
order = 30

[gpu]
enabled = true
provider = "auto"
label = "GPU"
order = 150
