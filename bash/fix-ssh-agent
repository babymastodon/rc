#!/usr/bin/env bash
# Keep one stable SSH agent socket for tmux/mosh.
#
# SSH shells register their incoming forwarded socket under ~/.ssh/agent/.
# ~/.ssh/agent_sock points at the selected registered socket. When that stable
# link is missing or dead, repair scans registered sockets, removes dead links,
# and falls back to common local desktop/user agent sockets.
#
# The forwarding/stable-link path is for anonymous VMs that hold no private key
# of their own. On a host that already has a key loaded in its own running agent
# (desktop keyring, gcr, a user ssh-agent), that local agent wins: an incoming
# forwarded agent must not shadow it.
set -u

link="${SSH_AUTH_SOCK_LINK:-$HOME/.ssh/agent_sock}"
dir="${SSH_AUTH_SOCK_DIR:-$HOME/.ssh/agent}"
session="${dir}/${HOSTNAME:-host}.${PPID}"
ssh_add=
# Resolve `timeout` once; used to bound ssh-add against wedged forwarded agents.
timeout_bin="$(command -v timeout 2>/dev/null || true)"

find_ssh_add() {
  [[ -n "$ssh_add" ]] && return 0
  ssh_add="$(command -v ssh-add 2>/dev/null || true)"
  [[ -n "$ssh_add" ]]
}

# Probe a socket with `ssh-add -l`, bounded by `timeout` so a forwarded agent
# that accepts the connection but never replies can't hang us. Returns ssh-add's
# exit code: 0 = has keys, 1 = reachable but empty, anything else (2 unreachable,
# 124 timeout, missing socket / no ssh-add) = treat as dead.
agent_probe() {
  local sock="$1"
  [[ -n "$sock" && -S "$sock" ]] || return 2
  find_ssh_add || return 2
  SSH_AUTH_SOCK="$sock" ${timeout_bin:+$timeout_bin 1} "$ssh_add" -l >/dev/null 2>&1
}

agent_ok()       { agent_probe "$1"; local s=$?; (( s == 0 || s == 1 )); }
agent_has_keys() { agent_probe "$1"; local s=$?; (( s == 0 )); }

# Well-known agent sockets owned by the host itself (not an incoming forward),
# in preference order.
local_agent_socks() {
  local rt="${XDG_RUNTIME_DIR:-/run/user/${UID:-$(id -u)}}"
  printf '%s\n' "$rt/keyring/ssh" "$rt/openssh_agent" "$rt/gcr/ssh"
}

is_self_ssh() {
  local client_ip server_ip
  [[ -n "${SSH_CONNECTION:-}" ]] || return 1

  read -r client_ip _ server_ip _ <<< "$SSH_CONNECTION"
  [[ -n "$client_ip" && "$client_ip" == "$server_ip" ]] && return 0

  case "$client_ip" in
    127.*|::1|::ffff:127.*) return 0 ;;
  esac
  return 1
}

relink() {
  local target="$1" dest="$2" tmp
  [[ "$target" != "$dest" ]] || return 0

  mkdir -p "${dest%/*}" || return 1
  tmp="${dest}.$$"
  rm -f "$tmp" 2>/dev/null
  ln -s "$target" "$tmp" 2>/dev/null || return 1
  mv -Tf "$tmp" "$dest" 2>/dev/null \
    || mv -f "$tmp" "$dest" 2>/dev/null \
    || { rm -f "$tmp" 2>/dev/null; return 1; }
}

register_incoming() {
  local sock="$1" cand
  [[ -n "$sock" && "$sock" != "$link" ]] || return 1
  is_self_ssh && agent_ok "$link" && return 0

  # If this host already has a key loaded — in the current link or a local
  # desktop/keyring agent — keep that and ignore the incoming forward. Only
  # anonymous VMs (no local key) fall through to registering the forward.
  agent_has_keys "$link" && return 0
  while IFS= read -r cand; do
    agent_has_keys "$cand" || continue
    relink "$cand" "$link"
    return $?
  done < <(local_agent_socks)

  agent_ok "$sock" || return 1
  mkdir -p "$dir" || return 1
  chmod 700 "$HOME/.ssh" "$dir" 2>/dev/null || true
  relink "$sock" "$session" || return 1
  relink "$session" "$link"
}

# Point the stable link at a working agent: keep it if already live, else adopt
# a live registered session socket (reaping dead ones), else a local agent. The
# link is probed, not just stat'd: a forwarded socket orphaned by a dropped
# connection stays a live socket but never replies, so -S alone isn't enough.
repair() {
  local selected= sock

  [[ -S "$link" ]] && agent_ok "$link" && return 0

  for sock in "$dir"/*; do
    [[ -e "$sock" || -L "$sock" ]] || continue
    if agent_ok "$sock"; then
      [[ -n "$selected" ]] || selected="$sock"
    elif [[ -L "$sock" ]]; then
      rm -f "$sock" 2>/dev/null
    fi
  done
  [[ -n "$selected" ]] && { relink "$selected" "$link"; return $?; }

  while IFS= read -r sock; do
    agent_ok "$sock" && { relink "$sock" "$link"; return $?; }
  done < <(local_agent_socks)

  return 1
}

# Register the inherited $SSH_AUTH_SOCK (an incoming forward at login), then
# repair the stable link. Both no-op when there's nothing new, so this just fixes.
register_incoming "${SSH_AUTH_SOCK:-}"
repair
